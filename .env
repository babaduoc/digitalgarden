STYLE_SETTINGS_CSS=/* Xanh SM Premium CSS */
:root {
  --bg-color: #f8fcfc;
  --brand-color: #00b2a9;
  --navy-color: #12263f;
  --text-color: #2d3b2d;
  --font-family: 'Outfit', sans-serif;
}
body {
  background-color: var(--bg-color) !important;
  font-family: var(--font-family) !important;
}
h1, h2, h3 {
  color: var(--brand-color) !important;
  font-weight: 800 !important;
}
a {
  color: var(--brand-color) !important;
  border-bottom: 1px dashed var(--brand-color);
}
.markdown-rendered blockquote {
  border-left: 5px solid var(--brand-color) !important;
  background: rgba(0, 178, 169, 0.05) !important;
}
STYLE_SETTINGS_BODY_CLASSES=
USE_FULL_RESOLUTION_IMAGES=false
THEME=https://raw.githubusercontent.com/Quinta0/Mint-Breeze/HEAD/theme.css
BASE_THEME=light
dgHomeLink=true
dgPassFrontmatter=false
dgShowBacklinks=false
dgShowLocalGraph=false
dgShowInlineTitle=false
dgShowFileTree=false
dgEnableSearch=false
dgShowToc=false
dgLinkPreview=false
dgShowTags=false